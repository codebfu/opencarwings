server {
    listen 80;
    listen [::]:80;
    server_name {{ opencarwings_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ opencarwings_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ opencarwings_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ opencarwings_domain }}/privkey.pem;

    location /static/ {
        alias {{ opencarwings_app_dir }}/staticfiles/;
        access_log off;
        expires 7d;
        add_header Cache-Control "public";
    }

    location /data/ {
        alias {{ opencarwings_app_dir }}/mediafiles/;
        access_log off;
        expires 1d;
        add_header Cache-Control "public";
    }

    location / {
        proxy_pass {{ opencarwings_proxy_pass_url }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
