TZ=Europe/Helsinki
BACKEND_PORT=0.0.0.0:8080
TCPSERVER_PORT=0.0.0.0:55230
PSQL_NAME=opencarwings
PSQL_USERNAME=opencarwings
# Must be non-empty and match the Postgres data directory initialization.
# If you change this after the DB was first created, either set the role
# password in PostgreSQL or remove ./postgres-data and recreate the stack.
PSQL_PASSWORD=changeme
SMSAPI_BASE_URL=http://smsapi:8000
SMSAPI_TIMEOUT=10
SMS_CREDENTIALS_ENCRYPTION_KEY=change_me_encryption_key
CARWINGS_GATEWAY_SHARED_SECRET=
CARWINGS_MAX_HTTP_PAYLOAD_BYTES=1048576
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30